{
  "name": "Retail Revenue Intelligence",
  "dataColors": [
    "#2563EB",
    "#7C3AED",
    "#06B6D4",
    "#38BDF8",
    "#A78BFA",
    "#0F766E",
    "#F59E0B",
    "#EF4444"
  ],
  "background": "#F8FAFC",
  "foreground": "#0F172A",
  "tableAccent": "#2563EB",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "fontColor": {
              "solid": {
                "color": "#0F172A"
              }
            },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E2E8F0"
              }
            },
            "radius": 6
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#0F172A"
              }
            },
            "fontSize": 22,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "color": {
              "solid": {
                "color": "#475569"
              }
            },
            "fontSize": 10
          }
        ]
      }
    }
  }
}
